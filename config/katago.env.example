# Primary KataGo runtime selection for this project.
# This setup prefers the OpenCL build because it already runs correctly on this machine.

KATAGO_BACKEND=opencl
KATAGO_EXECUTABLE=tools/katago/opencl/katago.exe
KATAGO_MODEL=models/katago/kata1-b18c384nbt-s9372115968-d4150170048.bin.gz
KATAGO_ANALYSIS_CONFIG=config/katago-analysis.cfg
KATAGO_GTP_CONFIG=config/katago-gtp.cfg

# OpenCL device selection:
# Benchmark/tuning showed device 0 is the NVIDIA GeForce RTX 5060 Laptop GPU.
KATAGO_OPENCL_DEVICE=0

# Lightweight defaults suitable for interactive beginner analysis.
KATAGO_MAX_VISITS=400
KATAGO_FAST_MAX_VISITS=200
KATAGO_DEEP_MAX_VISITS=800

# Keep LM Studio and desktop rendering in mind. Increase carefully.
KATAGO_NUM_SEARCH_THREADS=6
KATAGO_NUM_ANALYSIS_THREADS=1
KATAGO_NUM_SEARCH_THREADS_PER_ANALYSIS=8
KATAGO_NN_CACHE_SIZE_POW2=21
